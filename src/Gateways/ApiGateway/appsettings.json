{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "Issuer": "IdentityService",
    "Audience": "ECommerceMicroservices"
  },
  "ReverseProxy": {
    "Routes": {
      
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/Auth/{**remainder}" },
        "Transforms": [{ "PathPattern": "/api/Auth/{**remainder}" }],
        "RateLimiterPolicy": "fixed-window"
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/Product/{**remainder}" },
        "Transforms": [{ "PathPattern": "/api/Product/{**remainder}" }],
        "RateLimiterPolicy": "fixed-window"
      },
      "basket-api-route": {
        "ClusterId": "basket-cluster",
        "Match": { "Path": "/api/Basket/{**remainder}" },
        "Transforms": [{ "PathPattern": "/api/Basket/{**remainder}" }],
        "RateLimiterPolicy": "fixed-window"
      },

      
      "frontend-cart-route": {
        "ClusterId": "frontend-cart-cluster",
        "Match": { "Path": "/basket/{**remainder}" }
        
      },

      
      "frontend-home-route": {
        "ClusterId": "frontend-home-cluster",
        "Match": { "Path": "{**remainder}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": { "destination1": { "Address": "http://identity-service:80" } }
      },
      "product-cluster": {
        "Destinations": { "destination1": { "Address": "http://product-service:80" } }
      },
      "basket-cluster": {
        "Destinations": { "destination1": { "Address": "http://basket-service:80" } }
      },
      "frontend-cart-cluster": {
        "Destinations": { "destination1": { "Address": "http://frontend-cart:3000" } }
      },
      "frontend-home-cluster": {
        "Destinations": { "destination1": { "Address": "http://frontend-home:3000" } }
      }
    }
  }
}