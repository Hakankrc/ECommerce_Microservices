{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "JwtSettings": {
    "Secret": "YOUR_PASSWORD_HERE",
    "Issuer": "IdentityService",
    "Audience": "ECommerceMicroservices"
  },

  "ReverseProxy": {
    "Routes": {
      
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/Auth/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/Auth/{**remainder}" }
        ],
        "RateLimiterPolicy": "fixed-window"
      },
      
      "product-route": {
        "ClusterId": "product-cluster",
        "AuthorizationPolicy": "AuthenticatedUser",
        "Match": {
          "Path": "/api/Product/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/Product/{**remainder}" }
        ]
      },
      
      "basket-route": {
        "ClusterId": "basket-cluster",
        "Match": {
          
          "Path": "/api/Basket/{**remainder}"
        },
        "Transforms": [
          
          { "PathPattern": "/api/Basket/{**remainder}" }
        ]
      },
      
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/Order/{**remainder}"
        },
        "Transforms": [
          { "PathPattern": "/api/Order/{**remainder}" }
        ]
      }
    },
    "Clusters": {
      
      "auth-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://127.0.0.1:5113"
          }
        }
      },
      
      "product-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://127.0.0.1:5063"
          }
        }
      },
      
      "basket-cluster": {
        "Destinations": {
          "destination1": {
            
            "Address": "http://127.0.0.1:5287" 
          }
        }
      },
      
      "order-cluster": {
        "Destinations": {
          "destination1": {
             
            "Address": "http://127.0.0.1:5187"
          }
        }
      }
    }
  }
}